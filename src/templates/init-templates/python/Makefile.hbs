# Makefile for Python workspaces.
#
# Provides a normalized interface for Python venv setup, package management,
# and cx packaging.
#
# Usage:
#   make          # install dependencies and validate the environment
#   make build    # run any project-specific build step (if defined)
#   make test     # run unit tests
#   make bundle   # package a cx bundle
#   make validate # validate the cx configuration
#   make inspect  # show the computed bundle plan
#   make clean    # remove generated artifacts
#
PYTHON ?= python3
PIP ?= pip
CX ?= cx
CX_CONFIG ?= cx.toml
CLEAN_DIR ?= dist

.PHONY: all build test bundle validate inspect clean notes help
all: build

build: ## Install dependencies using pip and run the build step if available.
	$(PIP) install -r requirements.txt
	@echo "No additional Python build step defined."

test: ## Run Python tests if a test suite exists.
	$(PYTHON) -m pytest

bundle: build ## Build native artifacts, then package a cx bundle.
	$(CX) bundle --config "$(CX_CONFIG)"

inspect: ## Show the computed bundle plan.
	$(CX) inspect --config "$(CX_CONFIG)"

validate: ## Validate the cx configuration.
	$(CX) validate --config "$(CX_CONFIG)"

clean: ## Remove generated output files.
	rm -rf "$(CLEAN_DIR)" .pytest_cache __pycache__

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test bundle validate inspect clean notes\n"
