# Makefile for Rust workspaces.
#
# Provides a normalized interface for Cargo builds and cx packaging.
#
# Usage:
#   make          # build the Rust project in release mode
#   make build    # cargo build --release
#   make test     # cargo test
#   make check    # cargo check
#   make bundle   # build and package the cx bundle
#   make validate # validate the cx configuration
#   make inspect  # show the computed bundle plan
#   make clean    # remove generated output
#
CARGO ?= cargo
CX ?= cx
CX_CONFIG ?= cx.toml
CLEAN_DIR ?= dist

.PHONY: all build test check bundle validate inspect clean notes help
all: build

build: ## Build the Rust project in release mode.
	$(CARGO) build --release

test: ## Run Rust tests.
	$(CARGO) test

check: ## Check the project for compilation errors.
	$(CARGO) check

bundle: build ## Build native artifacts, then package a cx bundle.
	$(CX) bundle --config "$(CX_CONFIG)"

inspect: ## Show the computed bundle plan.
	$(CX) inspect --config "$(CX_CONFIG)"

validate: ## Validate the cx configuration.
	$(CX) validate --config "$(CX_CONFIG)"

clean: ## Remove generated output files.
	$(CARGO) clean
	rm -rf "$(CLEAN_DIR)"

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test check bundle validate inspect clean notes\n"
