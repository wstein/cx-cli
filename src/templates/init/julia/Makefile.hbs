# Makefile for Julia workspaces.
#
# Provides a normalized interface for Julia build commands and native workspace tasks.
#
# Usage:
#   make          # build the Julia project
#   make build    # julia --project build.jl
#   make test     # julia --project -e 'using Pkg; Pkg.test()'
#   make clean    # remove generated output
#   make notes    # show the notes directory path
#
JULIA ?= julia
CLEAN_DIR ?= dist

.PHONY: all build test clean notes help
all: build

build: ## Build the Julia project.
	$(JULIA) --project build.jl

test: ## Run Julia tests.
	$(JULIA) --project -e 'using Pkg; Pkg.test()'

clean: ## Remove generated output files.
	rm -rf "$(CLEAN_DIR)" build

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test clean notes\n"
