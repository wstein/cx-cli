# Makefile for Go workspaces.
#
# Provides a normalized interface for Go build commands and native workspace
# tasks.
#
# Usage:
#   make          # build the Go project
#   make build    # go build
#   make test     # go test
#   make clean    # remove generated output
#   make notes    # show the notes directory path
#
GO ?= go
CLEAN_DIR ?= dist

.PHONY: all build test clean notes help
all: build

build: ## Build the Go project.
	$(GO) build ./...

test: ## Run Go tests.
	$(GO) test ./...

clean: ## Remove generated output files.
	$(GO) clean
	rm -rf "$(CLEAN_DIR)"

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test clean notes\n"
