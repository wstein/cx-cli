# Makefile for Go workspaces.
#
# Provides a normalized interface for Go build commands and native workspace
# tasks.
#
# Usage:
#   make          # build the Go project
#   make build    # go build
#   make test     # go test
#   make check    # go vet
#   make verify   # check + test + build
#   make certify  # verify
#   make clean    # remove generated output
#   make notes    # show the notes directory path
#
GO ?= go
CLEAN_DIR ?= dist

.PHONY: all build test check verify certify clean notes help
all: build

build: ## Build the Go project.
	$(GO) build ./...

test: ## Run Go tests.
	$(GO) test ./...

check: ## Run Go vet across the workspace.
	$(GO) vet ./...

verify: ## Run the standard Go quality gate.
	@$(MAKE) check && $(MAKE) test && $(MAKE) build

certify: ## Run the local Go release gate.
	@$(MAKE) verify

clean: ## Remove generated output files.
	$(GO) clean
	rm -rf "$(CLEAN_DIR)"

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test check verify certify clean notes\n"
