# Makefile for Python workspaces.
#
# Provides a normalized interface for Python environment setup, package
# management, and native workspace tasks.
#
# Usage:
#   make          # install dependencies and validate the environment
#   make build    # run any project-specific build step (if defined)
#   make test     # run unit tests
#   make clean    # remove generated artifacts
#   make notes    # show the notes directory path
#
PYTHON ?= python3
PIP ?= pip
CLEAN_DIR ?= dist

.PHONY: all build test clean notes help
all: build

build: ## Install dependencies using pip if a requirements file is present.
	@if [ -f requirements.txt ]; then \
		$(PIP) install -r requirements.txt; \
	elif [ -f pyproject.toml ]; then \
		$(PYTHON) -m pip install .; \
	else \
		echo "No Python dependency manifest found; skipping install."; \
	fi

test: ## Run Python tests if a test suite exists.
	$(PYTHON) -m pytest

clean: ## Remove generated output files.
	rm -rf "$(CLEAN_DIR)" .pytest_cache __pycache__

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test clean notes\n"
