# Makefile for Crystal workspaces.
#
# Provides a normalized interface for Crystal build commands and native
# workspace tasks.
#
# Usage:
#   make          # build the Crystal project
#   make build    # crystal build src/main.cr --release
#   make test     # crystal spec
#   make verify   # test + build
#   make certify  # verify
#   make clean    # remove generated output
#   make notes    # show the notes directory path
#
CRYSTAL ?= crystal
SHARDS ?= shards
CLEAN_DIR ?= dist

.PHONY: all build test verify certify clean notes help
all: build

build: ## Build the Crystal project in release mode.
	@if [ -f shard.yml ] || [ -f shard.lock ]; then \
		$(SHARDS) build; \
	else \
		$(CRYSTAL) build src/main.cr --release; \
	fi

test: ## Run Crystal specs.
	$(CRYSTAL) spec

verify: ## Run the standard Crystal quality gate.
	@$(MAKE) test && $(MAKE) build

certify: ## Run the local Crystal release gate.
	@$(MAKE) verify

clean: ## Remove generated output files.
	rm -rf "$(CLEAN_DIR)" .crystal .shards

notes: ## Print the notes directory path.
	@printf "Notes directory: notes\n"

help: ## Show available targets.
	@printf "Available targets:\n  build test verify certify clean notes\n"
