{
  "name": "cx-cli",
  "version": "0.1.0",
  "description": "Deterministic context bundler built on top of Repomix.",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "bin": {
    "cx": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "bun test tests",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "verify": "bun run check && bun run build && bun test tests"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "dependencies": {
    "picomatch": "^4.0.4",
    "repomix": "^1.13.1",
    "smol-toml": "^1.6.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/yargs": "^17.0.33"
  }
}
