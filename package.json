{
  "name": "cx-cli",
  "version": "0.1.0",
  "description": "cx — an umbrella CLI for code context tooling",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "bin": {
    "cx": "./bin/cx"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun tsc",
    "dev": "bun tsc --watch",
    "start": "bun run dist/index.js",
    "check:shim": "node scripts/check-cx-portability.js",
    "check:rebuild": "node scripts/check-cx-rebuild.js",
    "test": "bun test",
    "lint": "bun tsc --noEmit"
  },
  "engines": {
    "bun": ">=1.3.11"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cac": "^6.7.14",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.5.11",
    "kleur": "^4.1.5",
    "repomix": "^1.13.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.0.0",
    "oxfmt": "^0.44.0",
    "typescript": "^5.8.0"
  }
}
