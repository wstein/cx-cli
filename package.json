{
  "name": "@wsmy/cx-cli",
  "version": "0.3.21",
  "description": "Deterministic context bundler built on top of Repomix.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "keywords": [
    "repomix",
    "bundler",
    "context",
    "cli",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": "./bin/cx",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "bin",
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-init-templates.js",
    "clean": "rm -rf dist",
    "format": "biome format --write .",
    "lint": "biome check . && node scripts/check-boundaries.js",
    "check-boundaries": "node scripts/check-boundaries.js",
    "test:unit": "bun test --coverage tests/unit --timeout 20000",
    "test:integration": "bun test --coverage tests/cli tests/bundle --timeout 20000",
    "test": "bun test --coverage tests --timeout 20000",
    "release": "node scripts/release.js",
    "gen:homebrew": "node scripts/generate-homebrew-formula.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "fix": "biome check --write --unsafe .",
    "verify": "bun run lint && bun run check && bun run build && bun test --coverage tests --timeout 20000 && node scripts/coverage-summary.js",
    "certify": "bun run verify && node scripts/reproducibility-check.js",
    "copy:init": "node scripts/copy-init-templates.js",
    "notes": "cx notes list && cx notes orphans",
    "smoke": "node scripts/repomix-version-smoke.js",
    "integrity": "node scripts/release-integrity.js",
    "verify-release": "node scripts/verify-release.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@wsmy/repomix-cx-fork": "^1.13.1-cx.4",
    "fast-xml-parser": "^5.6.0",
    "gpt-tokenizer": "^3.4.0",
    "handlebars": "^4.7.7",
    "kleur": "^4.1.5",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/yargs": "^17.0.35",
    "fast-check": "^4.6.0"
  }
}
