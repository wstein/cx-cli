{
  "name": "@wsmy/cx-cli",
  "version": "0.1.0",
  "description": "Deterministic context bundler built on top of Repomix.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "keywords": [
    "repomix",
    "bundler",
    "context",
    "cli",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "cx": "./bin/cx"
  },
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "bin",
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && bun run scripts/copy-init-templates.ts",
    "clean": "rm -rf dist",
    "format": "biome format --write .",
    "lint": "biome check .",
    "test": "bun test tests",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "verify": "bun run lint && bun run check && bun run build && bun test tests",
    "copy:init": "bun run scripts/copy-init-templates.ts"
  },
  "engines": {
    "node": ">=25.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@wsmy/repomix-cx-fork": "^1.13.1-cx.4",
    "fast-xml-parser": "^5.5.12",
    "gpt-tokenizer": "^3.4.0",
    "handlebars": "^4.7.7",
    "kleur": "^4.1.5",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "@types/yargs": "^17.0.35",
    "fast-check": "^4.6.0"
  }
}
