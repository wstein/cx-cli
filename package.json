{
  "name": "@wsmy/cx-cli",
  "version": "0.4.0",
  "description": "Kernel-owned context bundler for deterministic AI handoff and verification.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.12",
  "keywords": [
    "repomix",
    "bundler",
    "context",
    "cli",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": "./bin/cx",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "bin",
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-init-templates.js",
    "clean": "rm -rf dist",
    "format": "biome format --write .",
    "format:check": "biome check --formatter-enabled=true --linter-enabled=false --assist-enabled=false .",
    "lint": "biome check . && node scripts/check-boundaries.js",
    "check-boundaries": "node scripts/check-boundaries.js",
    "test:unit": "vitest run tests/unit",
    "test:all": "bun run test:vitest",
    "test:all:full": "bun run ci:test:coverage",
    "test:contracts": "vitest run tests/contracts",
    "test:vitest": "vitest run",
    "test:vitest:bundle": "vitest run tests/bundle tests/cli/render-adapter.test.ts tests/cli/main.json.test.ts",
    "test:vitest:notes": "vitest run tests/notes tests/unit/notesConsistency.test.ts tests/planning/linkedNotes.test.ts tests/contracts/linkedNotesOperator.contract.test.ts",
    "test:vitest:planning": "vitest run tests/planning tests/config/schema-integration.test.ts",
    "test:vitest:mcp": "vitest run --config vitest.mcp.config.ts",
    "test:vitest:mcp:adversarial": "vitest run --config vitest.mcp.adversarial.config.ts",
    "test:vitest:mcp:adversarial:ui": "vitest --config vitest.mcp.adversarial.config.ts --ui --coverage --open=false",
    "test:vitest:mcp:ui": "vitest --config vitest.mcp.config.ts --ui --coverage --open=false",
    "coverage:vitest": "vitest run --coverage",
    "coverage:vitest:mcp": "vitest run --config vitest.mcp.config.ts --coverage",
    "coverage:vitest:mcp:adversarial": "vitest run --config vitest.mcp.adversarial.config.ts --coverage",
    "coverage:report": "node scripts/coverage-report.js",
    "pages:build": "node scripts/assemble-pages-site.js",
    "pages:smoke": "node scripts/check-pages-site.js",
    "ci:test:coverage": "vitest run --coverage && node scripts/coverage-report.js",
    "ci:guard:fast-lane": "node scripts/check-fast-lane.js",
    "ci:report:verify-against": "node scripts/verify-against-policy.js --format json --output .ci/verify-against-policy-report.json",
    "ci:report:observability": "node scripts/ci-observability-report.js",
    "ci:test:fast": "bun run test:unit",
    "ci:test:fast:monitored": "node scripts/ci-test-fast-monitored.js",
    "ci:test:render-parity": "node scripts/render-parity-check.js",
    "ci:test:compat": "node scripts/bun-runtime-compat-smoke.js",
    "ci:test:contracts": "bun run test:contracts",
    "ci:test:adapter-capabilities-contract": "vitest run tests/contracts/adapterCapabilities.contract.test.ts",
    "ci:notes:governance": "node scripts/notes-governance.js",
    "ci:smoke:repomix-reference-oracle": "node scripts/repomix-reference-oracle-smoke.js",
    "ci:smoke:bundle-transition": "node scripts/bundle-transition-smoke.js",
    "ci:assurance:release-integrity": "node scripts/release-assurance-smoke.js",
    "ci:assurance:reproducibility": "node scripts/reproducibility-check.js",
    "test": "bun run test:unit",
    "release": "node scripts/release.js",
    "gen:homebrew": "node scripts/generate-homebrew-formula.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.scripts.json && tsc -p tsconfig.test.json",
    "fix": "biome check --write --unsafe .",
    "verify": "bun run lint && bun run check && bun run build && bun run ci:test:coverage && bun run ci:test:compat",
    "certify": "bun run verify && bun run ci:test:coverage && bun run ci:notes:governance && bun run ci:test:contracts && bun run ci:smoke:repomix-reference-oracle && bun run ci:smoke:bundle-transition && bun run ci:assurance:release-integrity && bun run ci:assurance:reproducibility",
    "copy:init": "node scripts/copy-init-templates.js",
    "notes": "cx notes list && cx notes orphans",
    "smoke": "bun run smoke:repomix-reference-oracle",
    "smoke:repomix-reference-oracle": "bun run ci:smoke:repomix-reference-oracle",
    "smoke:bundle-transition": "bun run ci:smoke:bundle-transition",
    "smoke:release-integrity": "bun run ci:assurance:release-integrity",
    "integrity": "node scripts/release-integrity.js",
    "verify-release": "node scripts/verify-release.js",
    "ci:test:native-render-contract": "vitest run tests/contracts/nativeRender.contract.test.ts"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.3.12"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "execa": "^9.6.1",
    "fast-xml-parser": "^5.7.1",
    "gpt-tokenizer": "^3.4.0",
    "handlebars": "^4.7.9",
    "kleur": "^4.1.5",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/yargs": "^17.0.35",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "fast-check": "^4.7.0",
    "repomix": "^1.13.1",
    "vitest": "^4.1.4"
  }
}
