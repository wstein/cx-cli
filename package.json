{
  "name": "@wsmy/cx-cli",
  "version": "0.3.16",
  "description": "Deterministic context bundler built on top of Repomix.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "keywords": [
    "repomix",
    "bundler",
    "context",
    "cli",
    "llm"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": "./bin/cx",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "bin",
    "dist",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && bun run scripts/copy-init-templates.ts",
    "clean": "rm -rf dist",
    "format": "biome format --write .",
    "lint": "biome check . && bun run scripts/check-boundaries.ts",
    "check-boundaries": "bun run scripts/check-boundaries.ts",
    "test:unit": "bun test tests/unit --timeout 20000",
    "test:integration": "bun test tests/cli tests/bundle --timeout 20000",
    "test": "bun test tests --timeout 20000",
    "coverage": "rm -rf coverage && bun test --coverage --coverage-dir coverage tests/unit --timeout 20000",
    "release": "bun run scripts/release.ts",
    "gen:homebrew": "bun run scripts/generate-homebrew-formula.ts",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "fix": "biome check --write .",
    "verify": "bun run lint && bun run check && bun run build && bun test --coverage --coverage-dir coverage tests --timeout 20000",
    "copy:init": "bun run scripts/copy-init-templates.ts",
    "smoke:repomix-version": "bun run scripts/repomix-version-smoke.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@wsmy/repomix-cx-fork": "^1.13.1-cx.4",
    "fast-xml-parser": "^5.6.0",
    "gpt-tokenizer": "^3.4.0",
    "handlebars": "^4.7.7",
    "kleur": "^4.1.5",
    "picomatch": "^4.0.4",
    "smol-toml": "^1.6.1",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/yargs": "^17.0.35",
    "fast-check": "^4.6.0"
  }
}
